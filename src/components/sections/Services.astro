---
import SectionHeading from '../ui/SectionHeading.astro';

const features = [
  {
    title: 'Diagnóstico y estrategia',
    description: 'Entendemos tu negocio, identificamos los cuellos de botella y definimos la solución óptima — antes de escribir una sola línea de código.',
    i18nTitle: 'services.feature1.title',
    i18nDesc: 'services.feature1.desc',
  },
  {
    title: 'Implementación pragmática',
    description: 'Construimos la solución con las herramientas correctas para tu problema, no con las que están de moda. Sin sobreingeniería, sin vueltas.',
    i18nTitle: 'services.feature2.title',
    i18nDesc: 'services.feature2.desc',
  },
  {
    title: 'Entrega y evolución',
    description: 'Lanzamos, monitoreamos y mejoramos continuamente. El software es el medio; la solución a tu problema es el fin.',
    i18nTitle: 'services.feature3.title',
    i18nDesc: 'services.feature3.desc',
  },
];

const steps = [
  {
    number: '01',
    title: 'Entendemos el problema',
    description: 'Analizamos tu negocio, usuarios y objetivos. Definimos alcance, timeline y presupuesto antes de empezar.',
    i18nTitle: 'services.step1.title',
    i18nDesc: 'services.step1.desc',
  },
  {
    number: '02',
    title: 'Diseñamos la solución',
    description: 'Sprints ágiles con demos semanales. Validamos cada decisión con vos antes de avanzar a la siguiente etapa.',
    i18nTitle: 'services.step2.title',
    i18nDesc: 'services.step2.desc',
  },
  {
    number: '03',
    title: 'Implementamos y evolucionamos',
    description: 'Deploy, monitoreo y soporte continuo. La solución crece con tu negocio — no desaparecemos después del launch.',
    i18nTitle: 'services.step3.title',
    i18nDesc: 'services.step3.desc',
  },
];
---

<section id="services" class="py-20 md:py-28 bg-surface-secondary" aria-label="Servicios">
  <div class="max-w-7xl mx-auto px-5 md:px-8 lg:px-10">
    <SectionHeading subtitleHtml="Identificamos el <span class=&quot;text-primary-500&quot;>desafío</span>, diseñamos la <span class=&quot;text-primary-500&quot;>solución</span>, la implementamos con <span class=&quot;text-primary-500&quot;>software</span>." titleKey="services.title" subtitleKey="services.subtitle">
      <span class="text-primary-500">Problemas</span> que resolvemos
    </SectionHeading>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {features.map((feature) => (
        <article class="bg-surface border border-border/60 rounded-lg p-8 hover:border-primary-500/30 hover:-translate-y-0.5 transition-all duration-500">
          <div class="w-10 h-10 rounded-lg bg-primary-500/10 flex items-center justify-center mb-5">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="text-primary-500" aria-hidden="true">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
            </svg>
          </div>
          <h3 class="font-heading text-lg font-normal tracking-[-0.01em] text-text-primary mb-3" data-i18n={feature.i18nTitle}>{feature.title}</h3>
          <p class="text-sm text-text-secondary leading-relaxed" data-i18n={feature.i18nDesc}>{feature.description}</p>
        </article>
      ))}
    </div>

    <div class="mt-20 md:mt-24">
      <div class="section-divider mb-16 md:mb-20">
        <span class="section-divider-mark" />
      </div>

      <p class="font-heading text-2xl md:text-3xl font-normal tracking-[-0.02em] text-text-primary text-center mb-4" data-i18n="services.heading2">
        De principio a fin, sin vueltas
      </p>
      <p class="text-text-secondary text-center mb-14 max-w-md mx-auto" data-i18n="services.sub2">
        Tres fases claras desde que identificamos el problema hasta que la solución está funcionando.
      </p>

      <div class="grid md:grid-cols-3 gap-8 md:gap-12 relative">
        <div class="hidden md:block absolute top-8 left-[calc(16.66%+1rem)] right-[calc(16.66%+1rem)] h-px bg-gradient-to-r from-primary-500/10 via-primary-500/30 to-primary-500/10" aria-hidden="true" />

        {steps.map((step) => (
          <article class="relative text-center md:text-left">
            <div class="hidden md:flex mx-auto md:mx-0 w-12 h-12 rounded-full bg-primary-500/10 border border-primary-500/20 text-primary-500 font-mono font-bold text-sm items-center justify-center relative z-10 mb-6">
              {step.number}
            </div>
            <div class="md:hidden flex items-center gap-4 mb-4">
              <span class="w-8 h-8 rounded-full bg-primary-500/10 border border-primary-500/20 text-primary-500 font-mono font-bold text-xs flex items-center justify-center shrink-0">
                {step.number}
              </span>
              <h3 class="font-heading text-xl font-normal text-text-primary" data-i18n={step.i18nTitle}>{step.title}</h3>
            </div>
            <h3 class="hidden md:block font-heading text-xl font-normal text-text-primary mb-3" data-i18n={step.i18nTitle}>{step.title}</h3>
            <p class="text-sm text-text-secondary leading-relaxed" data-i18n={step.i18nDesc}>{step.description}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>