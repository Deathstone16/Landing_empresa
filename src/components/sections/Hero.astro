---
import ScrollReveal from '../ui/ScrollReveal.astro';
---

<section class="relative pt-32 pb-24 md:pt-44 md:pb-36 overflow-hidden" aria-label="Hero">
  <div class="absolute inset-0 pointer-events-none bg-noise" aria-hidden="true" />
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute -top-1/2 -right-1/4 w-[800px] h-[800px] rounded-full bg-primary-500/[0.03] blur-3xl" />
    <div class="absolute -bottom-1/3 -left-1/4 w-[600px] h-[600px] rounded-full bg-secondary-400/[0.02] blur-3xl" />
  </div>

  <div class="absolute top-8 right-[10%] text-[32rem] font-heading font-normal leading-none text-primary-500/[0.02] select-none pointer-events-none hidden md:block" aria-hidden="true">
    N
  </div>

  <div class="relative max-w-7xl mx-auto px-5 md:px-8 lg:px-10">
    <div class="max-w-3xl">
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-normal leading-[1.08] tracking-[-0.02em] text-text-primary" data-i18n-html="hero.title">
        Tu negocio tiene problemas.
        <span class="text-primary-500">Los resolvemos con software</span>
        que funciona.
      </h1>

      <p class="mt-6 text-lg md:text-xl text-text-secondary leading-[1.7] max-w-xl" data-i18n-html="hero.subtitle">
        <span class="text-primary-500">Automatización</span>, <span class="text-primary-500">integración</span>, <span class="text-primary-500">digitalización</span>.
        Identificamos el problema, diseñamos la solución y la implementamos con
        <span class="text-primary-500">equipo senior</span>,
        <span class="text-primary-500">entregas predecibles</span> y cero sorpresas.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-start gap-4">
        <a href="#contact" class="inline-flex items-center justify-center gap-2.5 px-7 py-3.5 text-[15px] font-semibold tracking-[-0.01em] rounded-lg bg-primary-500 text-white btn-glow hover:bg-primary-600 active:scale-[0.97] transition-all duration-200 no-underline" data-i18n="hero.cta">
          Empezar un proyecto
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 3l5 5-5 5" />
          </svg>
        </a>
        <a href="#portfolio" class="inline-flex items-center gap-2.5 px-7 py-3.5 text-[15px] font-semibold tracking-[-0.01em] rounded-lg border border-border text-text-secondary hover:border-primary-500/40 hover:text-primary-500 transition-all duration-200 no-underline" data-i18n="hero.secundario">
          Ver trabajos
        </a>
      </div>

      <div class="mt-8 flex flex-wrap gap-x-8 gap-y-2 text-sm text-text-tertiary">
        <span class="flex items-center gap-1.5" data-i18n="hero.stat1">
          <span class="w-1.5 h-1.5 rounded-full bg-primary-500/60" aria-hidden="true" />
          Proyectos desde $25k
        </span>
        <span class="flex items-center gap-1.5" data-i18n="hero.stat2">
          <span class="w-1.5 h-1.5 rounded-full bg-primary-500/60" aria-hidden="true" />
          Respondemos en 24 hs
        </span>
        <span class="flex items-center gap-1.5" data-i18n="hero.stat3">
          <span class="w-1.5 h-1.5 rounded-full bg-primary-500/60" aria-hidden="true" />
          Sin compromiso
        </span>
      </div>
    </div>
  </div>
</section>
