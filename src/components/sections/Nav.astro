---
const navLinks = [
  { label: 'Trabajos', href: '#portfolio', i18n: 'nav.trabajos' },
  { label: 'Servicios', href: '#services', i18n: 'nav.servicios' },
  { label: 'Contacto', href: '#contact', i18n: 'nav.contacto' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 px-4 pt-4 transition-all duration-300" id="nav" data-nav>
  <nav class="max-w-7xl mx-auto px-4 md:px-6 flex items-center justify-between h-14 bg-surface border border-border/80 rounded-full transition-all duration-300" aria-label="Principal">
    <a href="/" class="flex items-center gap-2.5 no-underline font-heading font-normal text-xl text-text-primary hover:text-primary-500 transition-colors duration-200">
      <svg width="32" height="32" viewBox="0 0 28 28" fill="none" aria-hidden="true">
        <rect width="28" height="28" rx="6" fill="currentColor" class="text-primary-500"/>
        <path d="M8 20V8h4l4 6 4-6h4v12h-4V14l-4 6-4-6v6H8z" fill="currentColor" class="text-bg"/>
      </svg>
      Neadev
    </a>

    <div class="hidden md:flex items-center gap-1">
      {navLinks.map((link) => (
        <a href={link.href} class="group relative px-5 py-2 text-sm font-medium tracking-[-0.01em] text-text-primary/75 hover:text-primary-500 transition-colors duration-200 no-underline" data-i18n={link.i18n}>
          {link.label}
          <span class="absolute -bottom-1 left-4 right-4 h-0.5 bg-primary-500 rounded-full scale-x-0 group-hover:scale-x-100 transition-transform duration-300" />
        </a>
      ))}
      <a href="#contact" class="ml-3 inline-flex items-center px-5 py-2 text-sm font-semibold tracking-[-0.01em] rounded-full bg-primary-500 text-bg hover:bg-primary-300 active:scale-[0.98] transition-all duration-200 no-underline" data-i18n="nav.empezar">
        Hablemos
      </a>

      <button id="theme-toggle" class="ml-2 p-2 rounded-lg text-text-secondary/60 hover:text-primary-500 hover:bg-surface-secondary transition-all duration-200" type="button" aria-label="Cambiar modo claro">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="block light:hidden" aria-hidden="true">
          <circle cx="12" cy="12" r="5"/>
          <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
        </svg>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="hidden light:block" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
      <button id="lang-toggle" class="ml-1 p-2 rounded-lg text-text-primary/60 hover:text-primary-500 hover:bg-surface-secondary transition-all duration-200 text-xs font-semibold uppercase tracking-wider" type="button" data-i18n="lang.toggle" aria-label="Toggle language">
        EN
      </button>
    </div>

    <div class="flex md:hidden items-center gap-2">
      <button id="theme-toggle-mobile" class="p-2 rounded-lg text-text-secondary/60 hover:text-primary-500 transition-all duration-200" type="button" aria-label="Cambiar modo claro">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="block light:hidden" aria-hidden="true">
          <circle cx="12" cy="12" r="5"/>
          <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
        </svg>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="hidden light:block" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
      <button id="lang-toggle-mobile" class="p-2 rounded-lg text-text-primary/60 hover:text-primary-500 transition-all duration-200 text-xs font-semibold uppercase tracking-wider" type="button" data-i18n="lang.toggle" aria-label="Toggle language">
        EN
      </button>
      <button class="p-2 rounded-lg hover:bg-surface-secondary transition-colors duration-200 text-text-primary" type="button" aria-label="Abrir menú" aria-expanded="false" aria-controls="mobile-menu" data-menu-toggle>
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <line x1="4" x2="20" y1="7" y2="7" />
          <line x1="4" x2="20" y1="12" y2="12" />
          <line x1="4" x2="20" y1="17" y2="17" />
        </svg>
      </button>
    </div>
  </nav>

  <div id="mobile-backdrop" data-mobile-backdrop aria-hidden="true"></div>

  <div id="mobile-menu" class="md:hidden" data-mobile-menu style="display: none;">
    <div class="mobile-menu-header">
      <span class="text-[11px] font-mono tracking-[0.18em] uppercase text-text-tertiary">Navegación</span>
      <button class="p-2 rounded-lg text-text-secondary hover:text-primary-500 hover:bg-surface-secondary transition-all duration-200" type="button" aria-label="Cerrar menú" data-menu-close>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <path d="M18 6L6 18M6 6l12 12" />
        </svg>
      </button>
    </div>

    <nav class="flex flex-col px-6 py-1">
      {navLinks.map((link, i) => (
        <a href={link.href} class="mobile-nav-link" style={`--i: ${i}`} data-i18n={link.i18n}>
          {link.label}
        </a>
      ))}
    </nav>

    <div class="mobile-menu-footer">
      <a href="#contact" class="mobile-cta" data-i18n="nav.empezar">Empezar un proyecto</a>
      <a href="mailto:hello@neadev.dev" class="mobile-menu-email">hello@neadev.dev</a>
    </div>
  </div>
</header>

<script>
  const nav = document.querySelector('[data-nav]');
  const toggle = document.querySelector('[data-menu-toggle]');
  const closeBtn = document.querySelector('[data-menu-close]');
  const menu = document.querySelector('[data-mobile-menu]');
  const backdrop = document.querySelector('[data-mobile-backdrop]');

  const updateNavBorder = () => {
    if (window.scrollY > 50) {
      nav.style.borderBottomColor = 'var(--color-border)';
    } else {
      nav.style.borderBottomColor = 'var(--color-border-light)';
    }
  };

  window.addEventListener('scroll', updateNavBorder, { passive: true });
  updateNavBorder();

  function openMobileMenu() {
    backdrop.style.display = 'block';
    menu.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        backdrop.classList.add('open');
        menu.classList.add('open');
      });
    });
    toggle.setAttribute('aria-expanded', 'true');
  }

  function closeMobileMenu() {
    backdrop.classList.remove('open');
    menu.classList.remove('open');
    setTimeout(function () {
      if (!menu.classList.contains('open')) {
        menu.style.display = 'none';
        backdrop.style.display = 'none';
      }
    }, 350);
    document.body.style.overflow = '';
    toggle.setAttribute('aria-expanded', 'false');
  }

  toggle?.addEventListener('click', function () {
    var isOpen = toggle.getAttribute('aria-expanded') === 'true';
    if (isOpen) {
      closeMobileMenu();
    } else {
      openMobileMenu();
    }
  });

  closeBtn?.addEventListener('click', function () {
    closeMobileMenu();
    toggle?.focus();
  });

  window.addEventListener('keydown', function (event) {
    if (event.key === 'Escape') {
      closeMobileMenu();
      toggle?.focus();
    }
  });

  menu?.querySelectorAll('a').forEach(function (link) {
    link.addEventListener('click', function () {
      closeMobileMenu();
    });
  });

  backdrop?.addEventListener('click', function () {
    closeMobileMenu();
  });

  function toggleTheme() {
    var html = document.documentElement;
    var isLight = html.classList.toggle('light');
    localStorage.setItem('theme', isLight ? 'light' : 'dark');
  }

  document.querySelectorAll('#theme-toggle, #theme-toggle-mobile').forEach(function (btn) {
    btn.addEventListener('click', toggleTheme);
  });

  document.querySelectorAll('#lang-toggle, #lang-toggle-mobile').forEach(function (btn) {
    btn.addEventListener('click', window.__toggleLang);
  });
</script>
