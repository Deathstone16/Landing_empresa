---

<section id="contact" class="py-20 md:py-28 bg-surface-secondary" aria-label="Contacto">
  <div class="max-w-7xl mx-auto px-5 md:px-8 lg:px-10">
    <div class="section-divider mb-12" />

    <div class="max-w-2xl mx-auto text-center">
      <SectionHeading tag="h2" subtitleHtml="<span class=&quot;text-primary-500&quot;>Contanos</span> qué necesitás. Te respondemos en menos de 24 horas." titleKey="contact.title" subtitleKey="contact.subtitle">
        Construyamos algo grande juntos
      </SectionHeading>

      <a href="https://wa.me/5491123456789" target="_blank" rel="noopener noreferrer"
         class="mt-10 inline-flex items-center gap-3 px-8 py-4 text-[16px] font-semibold tracking-[-0.01em] rounded-xl bg-primary-500 text-white btn-glow hover:bg-primary-600 active:scale-[0.97] transition-all duration-200 no-underline">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        <span data-i18n="contact.cta">Empezar un proyecto</span>
      </a>

      <div class="mt-12 space-y-6">
        <div>
          <h3 class="text-sm font-semibold text-text-tertiary uppercase tracking-wider mb-3" data-i18n="contact.or">O escribinos a</h3>
          <a href="mailto:hello@norware.dev" class="inline-flex items-center gap-2.5 text-base text-text-secondary hover:text-primary-500 transition-colors duration-200 no-underline font-medium group">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="group-hover:text-primary-500 transition-colors duration-200" aria-hidden="true">
              <path d="M3 5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5z"/>
              <path d="M3 5l7 5 7-5"/>
            </svg>
            hello@norware.dev
          </a>
        </div>

        <div class="section-divider max-w-[6rem] !gap-2 my-6" />

        <div>
          <h3 class="text-sm font-semibold text-text-tertiary uppercase tracking-wider mb-4" data-i18n="contact.follow">Seguinos</h3>
          <div class="flex items-center justify-center gap-3">
            {socials.map((social) => (
              <a href={social.href} target="_blank" rel="noopener noreferrer"
                 class="w-10 h-10 rounded-lg bg-surface hover:bg-primary-500/10 hover:ring-1 hover:ring-primary-500/30 flex items-center justify-center transition-all duration-200 group"
                 aria-label={social.name}>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"
                     class="text-text-secondary group-hover:text-primary-500 transition-colors duration-200" aria-hidden="true">
                  <path d={social.path}/>
                </svg>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="section-divider mt-16" />
  </div>
</section>