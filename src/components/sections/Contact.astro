---
import SectionHeading from '../ui/SectionHeading.astro';
import ScrollReveal from '../ui/ScrollReveal.astro';

const socials = [
  {
    name: 'GitHub',
    href: 'https://github.com/neadev',
    path: 'M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z',
  },
  {
    name: 'LinkedIn',
    href: 'https://linkedin.com/company/neadev',
    path: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z',
  },
  {
    name: 'Instagram',
    href: 'https://instagram.com/neadev',
    path: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z',
  },
  {
    name: 'WhatsApp',
    href: 'https://wa.me/5491123456789',
    path: 'M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z',
  },
];
---

<section id="contact" class="py-20 md:py-28 bg-surface-secondary" aria-label="Contacto">
  <div class="max-w-7xl mx-auto px-5 md:px-8 lg:px-10">
    <div class="max-w-2xl mx-auto text-center">
      <ScrollReveal type="fade-up">
        <SectionHeading tag="h2" subtitleHtml="Contanos tu proyecto. Te respondemos en menos de <span class=&quot;text-primary-500&quot;>24 horas</span>." titleKey="contact.title" subtitleKey="contact.subtitle">
          <span class="text-primary-500">Hablemos</span>
        </SectionHeading>
      </ScrollReveal>
    </div>

    <div class="mt-14 md:mt-20 grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
      <ScrollReveal type="fade-up">
        <a data-magnetic href="https://wa.me/5491123456789" target="_blank" rel="noopener noreferrer"
           class="group flex flex-col items-center justify-center gap-4 p-8 rounded-xl bg-surface border border-border/60 hover:border-primary-500/30 transition-all duration-300 no-underline md:col-span-1">
          <span class="w-14 h-14 rounded-full bg-primary-500/10 flex items-center justify-center group-hover:bg-primary-500/20 transition-colors duration-300">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="text-primary-500" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </span>
          <div class="text-center">
            <span class="block font-heading text-lg font-normal text-text-primary group-hover:text-primary-500 transition-colors duration-300" data-i18n="contact.cta">WhatsApp</span>
            <span class="block text-sm text-text-secondary mt-1" data-i18n="contact.whatsapp-sub">Respondemos en 24 hs</span>
          </div>
        </a>
      </ScrollReveal>

      <ScrollReveal type="fade-up" class="md:col-span-1">
        <a data-magnetic href="mailto:hello@neadev.dev"
           class="group flex flex-col items-center justify-center gap-4 p-8 rounded-xl bg-surface border border-border/60 hover:border-primary-500/30 transition-all duration-300 no-underline h-full">
          <span class="w-14 h-14 rounded-full bg-primary-500/10 flex items-center justify-center group-hover:bg-primary-500/20 transition-colors duration-300">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary-500" aria-hidden="true">
              <path d="M22 4H2l10 8L2 4v16h20V4z"/>
              <path d="M22 4H2l10 8L2 4v16h20V4z"/>
            </svg>
          </span>
          <div class="text-center">
            <span class="block font-heading text-lg font-normal text-text-primary group-hover:text-primary-500 transition-colors duration-300">Email</span>
            <span class="block text-sm text-text-secondary mt-1">hello@neadev.dev</span>
          </div>
        </a>
      </ScrollReveal>

      <ScrollReveal type="fade-up" class="md:col-span-1">
        <div class="flex flex-col items-center justify-center gap-4 p-8 rounded-xl bg-surface border border-border/60 h-full">
          <span class="w-14 h-14 rounded-full bg-primary-500/10 flex items-center justify-center">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary-500" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </span>
          <div class="text-center">
            <span class="block font-heading text-lg font-normal text-text-primary">Respuesta rápida</span>
            <span class="block text-sm text-text-secondary mt-1">Garantizado en &lt;24 hs</span>
          </div>
        </div>
      </ScrollReveal>
    </div>

    <div class="mt-16 md:mt-20 max-w-4xl mx-auto">
      <ScrollReveal type="fade-up">
        <div class="rounded-xl bg-bg border border-border/40 p-8 md:p-10">
          <div class="flex flex-col md:flex-row items-center justify-between gap-6">
            <div>
              <h3 class="font-heading text-xl font-normal text-text-primary mb-2" data-i18n="contact.social-heading">Seguinos</h3>
              <p class="text-sm text-text-secondary" data-i18n="contact.social-sub">También estamos en redes</p>
            </div>
            <div class="flex items-center gap-3">
              {socials.map((social, i) => (
                <a href={social.href} target="_blank" rel="noopener noreferrer"
                   class="w-11 h-11 rounded-lg bg-surface border border-border/60 hover:border-primary-500/40 hover:bg-primary-500/[0.08] hover:-translate-y-0.5 flex items-center justify-center transition-all duration-300 group"
                   aria-label={social.name}>
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"
                       class="text-text-secondary group-hover:text-primary-500 transition-colors duration-300" aria-hidden="true">
                    <path d={social.path}/>
                  </svg>
                </a>
              ))}
            </div>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </div>
</section>
