---
import SectionHeading from '../ui/SectionHeading.astro';
import ScrollReveal from '../ui/ScrollReveal.astro';

interface Project {
  title: string;
  description: string;
  tags: string[];
  gradient: string;
  icon: string;
}

const projects: Project[] = [
  {
    title: 'Dashboard Financiero',
    description: 'Plataforma de análisis en tiempo real que procesa $50M+ en transacciones mensuales con consultas en milisegundos.',
    tags: ['React', 'Node.js', 'PostgreSQL', 'AWS'],
    gradient: 'from-primary-500/5 via-primary-500/10 to-transparent',
    icon: 'M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83',
  },
  {
    title: 'Plataforma E-commerce',
    description: 'Marketplace completo con CMS personalizado, inventario en tiempo real y 99.9% de uptime en 15 países.',
    tags: ['Next.js', 'Python', 'Redis', 'Docker'],
    gradient: 'from-secondary-400/5 via-secondary-400/10 to-transparent',
    icon: 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9zM9 22V12h6v10',
  },
  {
    title: 'App de Salud',
    description: 'Sistema de gestión de pacientes que atiende 200+ clínicas con manejo seguro de datos y agenda en tiempo real.',
    tags: ['React Native', 'Go', 'MongoDB', 'GCP'],
    gradient: 'from-primary-500/5 via-primary-500/10 to-transparent',
    icon: 'M22 12h-4l-3 9L9 3l-3 9H2',
  },
];
---

<section id="portfolio" class="py-20 md:py-28 bg-bg" aria-label="Trabajos seleccionados">
  <div class="max-w-7xl mx-auto px-5 md:px-8 lg:px-10">
    <SectionHeading subtitleHtml="Proyectos <span class=&quot;text-primary-500&quot;>reales</span>, <span class=&quot;text-primary-500&quot;>resultados concretos</span>." titleKey="portfolio.title" subtitleKey="portfolio.subtitle">
      Trabajos seleccionados
    </SectionHeading>

    <div class="grid md:grid-cols-3 gap-8 md:gap-10">
      {projects.map((project) => (
        <article class="group relative overflow-hidden rounded-lg border border-border/60 bg-surface hover:border-primary-500/30 transition-all duration-500">
          <div class={`aspect-[4/3] bg-gradient-to-br ${project.gradient} flex items-center justify-center relative overflow-hidden`}>
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-500/20 group-hover:text-primary-500/40 group-hover:scale-110 transition-all duration-500" aria-hidden="true">
              <path d={project.icon} />
            </svg>
            <div class="absolute inset-0 bg-gradient-to-t from-bg/80 via-bg/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <div class="absolute bottom-0 left-0 right-0 p-6 translate-y-2 group-hover:translate-y-0 transition-transform duration-300">
                <div class="flex flex-wrap gap-2">
                  {project.tags.map((tag) => (
                    <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-secondary-400/10 text-secondary-400 ring-1 ring-secondary-400/20 backdrop-blur-sm">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
          <div class="p-8">
            <h3 class="font-heading text-lg font-normal tracking-[-0.01em] text-text-primary mb-2">{project.title}</h3>
            <p class="text-sm text-text-secondary leading-relaxed">{project.description}</p>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
